{
  "EmpiricalFullPipeline.spec": {
    "barcode_key_files": ["path/to/keyfile1.txt", "path/to/keyfile2.txt"],
    "fastq_files":       ["path/to/lane1.fastq.gz", "path/to/lane2.fastq.gz"],
    "enzyme":            "EcoT22I",
    "enzyme2":           null,
    "adapter":           "AGATCGGAAGAGC"
  },

  "EmpiricalFullPipeline.ref_fasta": "path/to/genome.fasta",

  "EmpiricalFullPipeline.populations": [
    {
      "pedigree":          "CQxMQ",
      "pedigree_aliases":  ["MQxCQ"],
      "dataset": {
        "name":          "CQxMQ",
        "parent1":       "Crimson_Queen",
        "parent2":       "Mullica_Queen",
        "cross":         "outcross",
        "chromosomes":   null,
        "multiallelics": false
      }
    },
    {
      "pedigree":          "STxMQ",
      "pedigree_aliases":  ["MQxST"],
      "dataset": {
        "name":          "STxMQ",
        "parent1":       "Stevens",
        "parent2":       "Mullica_Queen",
        "cross":         "outcross",
        "chromosomes":   null,
        "multiallelics": false
      }
    }
  ],

  "EmpiricalFullPipeline.max_cores":  4,
  "EmpiricalFullPipeline.max_ram":    8000,
  "EmpiricalFullPipeline.chunk_size": 10,
  "EmpiricalFullPipeline.n_chrom":    3,

  "EmpiricalFullPipeline.rm_dupli":      false,
  "EmpiricalFullPipeline.pair_end":      false,
  "EmpiricalFullPipeline.gatk_mchap":    false,
  "EmpiricalFullPipeline.hardfilters":   true,
  "EmpiricalFullPipeline.replaceAD":     true,
  "EmpiricalFullPipeline.run_gatk":      true,
  "EmpiricalFullPipeline.run_freebayes": true,
  "EmpiricalFullPipeline.run_tassel":    true,
  "EmpiricalFullPipeline.ploidy":        2,

  "EmpiricalFullPipeline.replaceADbyMissing": "TRUE",

  "EmpiricalFullPipeline.filters":    null,
  "EmpiricalFullPipeline.prob_thres": null,
  "EmpiricalFullPipeline.filt_segr":  null,

  "_comment_populations": [
    "Each entry in 'populations' defines one mapping population.",
    "  pedigree         – canonical Pedigree value in GBS key files (e.g. 'CQxMQ')",
    "  pedigree_aliases – reciprocal cross notations for the same population (e.g. ['MQxCQ']); use [] if none",
    "  dataset.parent1/parent2 – SeedLot names as they appear in the VCF header (spaces replaced by underscores)",
    "  dataset.chromosomes – omit (null) to auto-detect from the VCF"
  ],
  "_comment_sub_workflow_overrides": [
    "Sub-workflow inputs can be overridden using dotted paths, e.g.:",
    "  EmpiricalFullPipeline.filter_noninfo:          false",
    "  EmpiricalFullPipeline.run_updog:          true",
    "  EmpiricalFullPipeline.run_supermassa:     false",
    "  EmpiricalFullPipeline.run_polyrad:        true",
    "  EmpiricalFullPipeline.run_gusmap:         false",
    "  EmpiricalFullPipeline.global_errors:      ['0.05']",
    "  EmpiricalFullPipeline.run_stacks:   false"
  ]
}
